# MongoDB connection string.
# Local:   mongodb://localhost:27017/chargehub
# Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/chargehub

MONGODB_URI=mongodb://127.0.0.1:27017/chargehub
# Secret used to sign NextAuth JWT sessions.
# Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-string
# Same value as NEXTAUTH_SECRET — kept for any code/tooling that reads JWT_SECRET directly.
JWT_SECRET=replace-with-a-long-random-string

# Base URL of the app (no trailing slash).
NEXTAUTH_URL=http://localhost:3000

# ── Optional ──────────────────────────────────────────────
# If set, the AI chatbot will use OpenAI to phrase answers.
# Without it, the chatbot still works using grounded database
# lookups (it just uses templated wording instead of an LLM).
# OPENAI_API_KEY=sk-...

# Real backend API (see /backend folder)
NEXT_PUBLIC_API_URL=http://localhost:4000
